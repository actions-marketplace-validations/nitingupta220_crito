# ── GitHub ──────────────────────────────────────────────────────────────────
# For webhook server mode. In GitHub Actions mode, GITHUB_TOKEN is auto-injected.
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── OpenRouter ───────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
# Store this as OPENROUTER_API_KEY in your repo's GitHub Actions secrets
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Model Chain (live-verified free defaults, 2026-06-02) ─────────────────
# OpenRouter models[] fallback array — max 3, comma-separated.
# Lead model (first) must be JSON-reliable. gpt-oss-120b is the safest.
# Customize per-agent or use these shared defaults.
FREE_MODEL_CHAIN=openai/gpt-oss-120b:free,qwen/qwen3-coder:free,z-ai/glm-4.5-air:free

# Per-agent model overrides (optional — defaults to free chain if not set)
# Bug and Performance lead with qwen3-coder (strongest free coder)
BUG_MODELS=qwen/qwen3-coder:free,openai/gpt-oss-120b:free,z-ai/glm-4.5-air:free
PERFORMANCE_MODELS=qwen/qwen3-coder:free,openai/gpt-oss-120b:free,z-ai/glm-4.5-air:free

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev/Actions): sqlite+aiosqlite:///./pr_review.db
# Postgres (prod):      postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./pr_review.db

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_DIFF_SIZE=50000
